---
/**
 * ProjectsPage — Shared page template for the projects/portfolio page.
 * Used by both src/pages/projects.astro (ES) and src/pages/en/projects.astro (EN).
 * Language is detected automatically from the URL.
 */
import type { CollectionPageStructuredData } from "@/types/seo";
import { SITE } from "@/config/site";
import { getLangFromUrl, getCanonicalUrl, translations } from "@/i18n";
import Introduction from "@/blocks/projects/Introduction/Introduction.astro";
import ProjectsListSection from "@/blocks/projects/ProjectsListSection/ProjectsListSection.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import CtaBanner from "@/components/layout/CtaBanner.astro";

// Detect current language from URL automatically
const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];

const seoTitle = t.projects.seo.title;
const seoDescription = t.projects.seo.description;
const seoKeywords = t.projects.seo.keywords;

const canonicalUrl = getCanonicalUrl(SITE.url, "/projects", currentLang);

const portfolioName =
  currentLang === "es"
    ? "Portfolio de Proyectos - Aurin"
    : "Project Portfolio - Aurin";

const catalogName =
  currentLang === "es"
    ? "Portfolio de Proyectos de Diseño"
    : "Design Project Portfolio";

const structuredData: CollectionPageStructuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: portfolioName,
  description: seoDescription,
  url: canonicalUrl,
  inLanguage: currentLang === "es" ? "es-MX" : "en-US",
  mainEntity: {
    "@type": "Organization",
    name: SITE.name,
    url: SITE.url,
    logo: SITE.logoUrl,
    hasOfferCatalog: {
      "@type": "OfferCatalog",
      name: catalogName,
      itemListElement: [
        {
          "@type": "CreativeWork",
          name: t.projects.projectTitles["proyecto-innovador-1"],
          description:
            currentLang === "es"
              ? "Proyecto de branding, UI/UX y desarrollo web"
              : "Branding, UI/UX and web development project",
          creator: {
            "@type": "Organization",
            name: SITE.name,
          },
          keywords: [
            t.projects.projectTags["Branding"],
            t.projects.projectTags["UI/UX"],
            t.projects.projectTags["Web"],
          ],
        },
        {
          "@type": "CreativeWork",
          name: t.projects.projectTitles["transformacion-digital"],
          description:
            currentLang === "es"
              ? "Proyecto de desarrollo y estrategia digital"
              : "Development and digital strategy project",
          creator: {
            "@type": "Organization",
            name: SITE.name,
          },
          keywords: [
            t.projects.projectTags["Desarrollo"],
            t.projects.projectTags["Estrategia"],
          ],
        },
        {
          "@type": "CreativeWork",
          name: t.projects.projectTitles["experiencia-usuario"],
          description:
            currentLang === "es"
              ? "Proyecto de investigación UX y diseño"
              : "UX research and design project",
          creator: {
            "@type": "Organization",
            name: SITE.name,
          },
          keywords: [
            t.projects.projectTags["UX Research"],
            t.projects.projectTags["Design"],
          ],
        },
      ],
    },
  },
};

// CSS selectors for speakable content (voice optimization)
const speakable = [
  ".projects-introduction",
  ".projects-strip",
  ".project-card",
];
---

<Layout
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  structuredData={structuredData}
  speakable={speakable}
  canonical={canonicalUrl}
  ogImage={SITE.logoUrl}
>
  <Header />
  <main id="main-content">
    <Introduction />
    <ProjectsListSection />
    <CtaBanner />
    <Footer />
  </main>
</Layout>
