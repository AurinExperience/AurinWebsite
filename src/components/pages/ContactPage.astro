---
/**
 * ContactPage — Shared page template for the contact page.
 * Used by both src/pages/contact.astro (ES) and src/pages/en/contact.astro (EN).
 * Language is detected automatically from the URL.
 */
import type { ContactPageStructuredData } from "@/types/seo";
import { SITE } from "@/config/site";
import { getLangFromUrl, getCanonicalUrl, translations } from "@/i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import HeroContact from "@/blocks/shared/Contact/HeroContact.astro";
import Form from "@/blocks/shared/Contact/Form.astro";
import Toast from "@/components/ui/Toast.astro";

// Detect current language from URL automatically
const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];

const seoTitle = t.contact.seo.title;
const seoDescription = t.contact.seo.description;
const seoKeywords = t.contact.seo.keywords;

const structuredData: ContactPageStructuredData = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  mainEntity: {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: SITE.name,
    url: SITE.url,
    logo: SITE.logoUrl,
    contactPoint: {
      "@type": "ContactPoint",
      email: SITE.contactEmail,
      contactType: "customer service",
    },
    address: {
      "@type": "PostalAddress",
      addressLocality: "Aldea Creativa",
      addressCountry: "MX",
    },
    sameAs: SITE.sameAs,
  },
};

// CSS selectors for speakable content (voice optimization)
const speakable = [".contact-form", ".contact-info"];

const canonicalUrl = getCanonicalUrl(SITE.url, "/contact", currentLang);
---

<Layout
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  structuredData={structuredData}
  speakable={speakable}
  canonical={canonicalUrl}
  ogImage={SITE.logoUrl}
>
  <Header />
  <main id="main-content">
    <HeroContact />
    <Form />
    <Toast />
    <Footer />
  </main>
</Layout>
