---
import { getLangFromUrl, translations } from '@/i18n';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import ProjectCard from '@/components/cards/ProjectCard.astro';
import ButtonIsland from '@/components/ui/ButtonIsland.astro';
import { PayloadAPI, getProjectUrl, getImageUrl, type PayloadProject } from '@/lib/payload';
import styles from './Projects.module.css';

interface Props {
  maxProjects?: number;
  showChips?: boolean;
  variant?: 'three-column' | 'four-column';
}

const {
  maxProjects = 3,
  showChips = true,
  variant = 'three-column'
} = Astro.props;

const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];

function shuffleArray<T>(array: T[]): T[] {
  const shuffled = [...array];
  for (let i = shuffled.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
  }
  return shuffled;
}

let projects: PayloadProject[] = [];
try {
  const allProjects = await PayloadAPI.getProjects(currentLang);
  projects = shuffleArray(allProjects).slice(0, maxProjects);
} catch (error) {
  console.error('Error fetching projects:', error);
}
---

<section class={styles.projects}>
  <div class={styles.projectsContainer}>
    <div class={styles.headerSection}>
      <SectionHeading
        lightText={t.projects.headingLight}
        highlightText={t.projects.headingHighlight}
      />
      <ButtonIsland
        text={t.projects.buttonText}
        href={currentLang === 'es' ? '/projects' : '/en/projects'}
        variant="primary"
      />
    </div>

    <div class={`${styles.projectsGrid} ${variant === 'four-column' ? styles.projectsGridFourColumn : ''}`}>
      {projects.length > 0 ? (
        projects.map((project) => (
          <ProjectCard
            title={project.title}
            tags={[...(project.category ? [project.category.name] : [])]}
            image={getImageUrl(project.hero.bannerImage?.url) || 'https://placehold.co/800x600?text=No+Image'}
            href={getProjectUrl(project, currentLang)}
            services={showChips ? (project.hero.services || []) : []}
            filters={project.projectFilters || []}
          />
        ))
      ) : (
        <>
          <ProjectCard
            title="Galicia"
            tags={[t.projects.tags.uxui, t.projects.tags.frontBack]}
            image="https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/ProjectGalicia.webp"
            href="/projects/galicia"
            services={showChips ? [{name: "UX/UI"}] : []}
          />
          <ProjectCard
            title="Sinfonica de<br/>Minería"
            tags={[t.projects.tags.uxui, t.projects.tags.frontBack]}
            image="https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/ProjectSinfonica.webp"
            href="/projects/sinfonica"
            services={showChips ? [{name: "Branding"}] : []}
          />
          <ProjectCard
            title="SAI Derecho y economía"
            tags={[t.projects.tags.uxui, t.projects.tags.frontBack]}
            image="https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/ProjectSai.webp"
            href="/projects/sai"
            services={showChips ? [{name: "Desarrollo"}] : []}
          />
          {maxProjects >= 4 && (
            <ProjectCard
              title={currentLang === 'en' ? 'Extra Project' : 'Proyecto Extra'}
              tags={[t.projects.tags.uxui]}
              image="https://placehold.co/800x600?text=Proyecto+4"
              href="/projects"
              services={showChips ? [{name: "Digital"}] : []}
            />
          )}
        </>
      )}
    </div>
  </div>
</section>
