---
import { getLangFromUrl, translations } from "@/i18n";
// Footer component with parallax effect
import styles from "./Footer.module.css";

// Detect current language
const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];

const copyright = t.footer.copyright.replace("{year}", new Date().getFullYear().toString());
---

<div data-footer-parallax>
  <footer data-footer-parallax-inner class={styles.stickyFooter}>
    <div class={styles.stickyContainer}>
      <div class={styles.footerContent}>
        <img
          src="https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/Light.svg"
          alt=""
          class={styles.glow}
          data-footer-glow
          aria-hidden="true"
        />
        <div class={styles.footerContainer}>
          <div class={styles.footerContentInner}>
            <div class={`${styles.footerLogoContainer} footer-logo`}>
              <img
                class={styles.footerLogo}
                src="https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/aurinWhiteLogo.svg"
                alt="Aurin Logo"
              />
              <p class={styles.footerTagline}>{t.footer.tagline}</p>
            </div>

            <div class={styles.footerColumns}>
              <!-- Contacto -->
              <div class={`${styles.footerSection} ${styles.sectionContact} footer-column`}>
                <h3 class={styles.footerTitle}>{t.footer.contact}</h3>
                <div class={styles.footerLinkContainer}>
                  <a href="mailto:hey@aurin.mx" class={styles.footerLink}>hey@aurin.mx</a>
                </div>
              </div>

              <!-- Legales -->
              <div class={`${styles.footerSection} ${styles.sectionLegal} footer-column`}>
                <h3 class={styles.footerTitle}>{t.footer.legal}</h3>
                <div class={styles.footerLinkContainer}>
                  <a href="/privacy" class={styles.footerLink}>{t.footer.privacyPolicy}</a>
                </div>
                <div class={styles.footerLinkContainer}>
                  <a href="/terms" class={styles.footerLink}>{t.footer.termsConditions}</a>
                </div>
              </div>

              <!-- Oficinas -->
              <div class={`${styles.footerSection} ${styles.sectionOffices} footer-column`}>
                <h3 class={styles.footerTitle}>{t.footer.offices}</h3>
                <div class={styles.footerLinkContainer}>
                  <a
                    href="https://aldeacreativa.mx/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class={styles.footerLink}>{t.footer.officesLink}</a
                  >
                </div>
              </div>
            </div>
          </div>

          <div class={`${styles.footerCopyright} footer-copyright`}>
            <p>{copyright}</p>
          </div>
        </div>
      </div>
    </div>
  </footer>
</div>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Aim the glow at the logo so it reads like a light hitting it — vertically aligned
  // with the logo's center, in every resolution. The glow must stay full-width (touching
  // the screen's left edge), so it lives outside the padded container and is placed via JS.
  function positionGlow() {
    const glow = document.querySelector("[data-footer-glow]") as HTMLElement;
    if (!glow) return;

    // Mobile uses the CSS rule (top: 0); clear any inline value set on larger screens.
    if (window.innerWidth <= 768) {
      glow.style.top = "";
      glow.style.transform = "";
      return;
    }

    const logo = document.querySelector(".footer-logo") as HTMLElement;
    const content = glow.parentElement as HTMLElement;
    if (!logo || !content) return;

    const contentTop = content.getBoundingClientRect().top;
    const logoRect = logo.getBoundingClientRect();
    const logoCenter = logoRect.top + logoRect.height / 2 - contentTop;

    // The light's pointing tip isn't at the image's geometric center: in the SVG
    // (viewBox 0 0 1536 445) the left tip spans y 194–313, so its center sits at ~0.57
    // of the height. Align that tip with the logo center so the beam lands on the logo.
    const TIP_FRACTION = 0.57;
    const glowHeight = glow.getBoundingClientRect().height;
    glow.style.transform = "none";
    glow.style.top = `${logoCenter - TIP_FRACTION * glowHeight}px`;
  }

  function initFooter() {
    positionGlow();
    window.addEventListener("resize", positionGlow, { passive: true });

    // 1. Initialize Parallax Effect (desktop only, and tall enough screens)
    if (window.innerWidth > 768 && window.innerHeight > 750) {
      const footerElements = document.querySelectorAll("[data-footer-parallax]");

      footerElements.forEach((el) => {
        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: el,
            start: "clamp(top bottom)",
            end: "clamp(top top)",
            scrub: true,
          },
        });

        const inner = el.querySelector("[data-footer-parallax-inner]");

        if (inner) {
          tl.from(inner, {
            yPercent: -20,
            ease: "linear",
          });
        }
      });
    }

    // 2. Initialize Intersection Observer for Animations
    const footerLogo = document.querySelector(".footer-logo") as HTMLElement;
    const footerColumns = document.querySelectorAll(".footer-column");

    const observerOptions = {
      threshold: 0.2,
      rootMargin: "0px 0px -50px 0px",
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.setAttribute("data-visible", "true");
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    // Animate logo
    if (footerLogo) {
      footerLogo.style.transitionDelay = "0.2s";
      observer.observe(footerLogo);
    }

    // Animate columns with staggered delay
    footerColumns.forEach((column, index) => {
      (column as HTMLElement).style.transitionDelay = `${0.3 + index * 0.15}s`;
      observer.observe(column);
    });
  }

  // Initialize on DOM ready
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initFooter);
  } else {
    initFooter();
  }

  // Re-initialize on route changes (for SPA-like behavior in Astro)
  document.addEventListener("astro:after-swap", initFooter);
</script>
