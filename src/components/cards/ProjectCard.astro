---
import { ArrowUpRight } from 'lucide-astro';
import styles from './ProjectCard.module.css';
import { Tilt } from '@/components/animation/Tilt';

interface Props {
  title: string;
  tags?: string[];
  image: string;
  href?: string;
  class?: string;
  category?: string;
  services?: Array<{ name: string }>;
  filters?: string[];
  showChips?: boolean;
}

const {
  title,
  tags = [],
  image,
  href = '#',
  class: className = '',
  category,
  services = [],
  filters = [],
  showChips = true
} = Astro.props;

const uniqueId = `project-card-${Math.random().toString(36).substr(2, 9)}`;

const allTags = [...(tags || []), ...(services ? services.map(s => s.name) : [])];
// If the first tag is too long, only show 1 tag to prevent the second tag's dot from rendering weirdly
const displayCount = (allTags[0] && allTags[0].length > 18) ? 1 : 2;
const displayTags = allTags.slice(0, displayCount);
const remainingCount = allTags.length - displayCount;
const hiddenTags = allTags.slice(displayCount);
---

<a href={href} class={`${styles['project-card']} ${className}`} data-card-id={uniqueId} data-project-card data-category={category} data-filters={JSON.stringify(filters)}>
  {remainingCount > 0 && (
    <div class={styles['tooltip']} data-tooltip>
      {hiddenTags.join(' • ')}
    </div>
  )}
  <div class={styles['card-content']}>
    <!-- Image container -->
    <Tilt 
      client:visible
      rotationFactor={2}
      className="w-full h-full rounded-lg overflow-hidden"
      style={{ transformOrigin: 'center center' }}
    >
      <div class={styles['image-container']} style={`background-image: url('${image}')`}>
        <div class={styles['image-overlay']}></div>
      </div>
    </Tilt>
    
    <!-- Info section -->
    <div class={styles['info-section']}>
      <div class={styles['info-content']}>
        <!-- Tags (Services and categories) -->
        {allTags.length > 0 && (
          <div class={styles['tags-container']}>
            {displayTags.map((tag) => (
              <div class={styles['tag-item']}>
                <div class={styles['tag-dot']}></div>
                <div class={styles['tag-text']}>{tag}</div>
              </div>
            ))}
            {remainingCount > 0 && (
              <div class={`${styles['tag-item']} ${styles['tag-count']}`}>
                <div class={styles['tag-dot']}></div>
                <div class={styles['tag-text']}>+{remainingCount}</div>
              </div>
            )}
          </div>
        )}

        <!-- Title -->
        <h3 class={styles['project-title']} set:html={title}></h3>
      </div>

      <!-- Arrow button -->
      <div class={styles['arrow-button']} data-arrow-button>
        <ArrowUpRight size={16.67} strokeWidth={2.5} />
      </div>
    </div>
  </div>
</a>

<script is:inline>
  (function() {
    function initProjectCards() {
      const cards = document.querySelectorAll('[data-card-id]');
      
      cards.forEach((card) => {
        const arrowButton = card.querySelector('[data-arrow-button]');
        
        if (!arrowButton) return;
        
        // Sincronizar hover
        const handleEnter = () => card.classList.add('is-hovering');
        const handleLeave = () => card.classList.remove('is-hovering');
        
        arrowButton.addEventListener('mouseenter', handleEnter);
        arrowButton.addEventListener('mouseleave', handleLeave);
      });

      // Animación de scroll con IntersectionObserver
      const observerOptions = {
        threshold: 0.2,
        rootMargin: '0px 0px -50px 0px'
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);

      cards.forEach((card, index) => {
        // Delay más rápido para mejor UX
        card.style.transitionDelay = `${index * 0.08}s`;
        observer.observe(card);

        // Tooltip logic
        const tooltip = card.querySelector('[data-tooltip]');
        if (tooltip) {
          card.addEventListener('mousemove', (e) => {
            const rect = card.getBoundingClientRect();
            let x = e.clientX - rect.left;
            let y = e.clientY - rect.top - 20; // 20px above cursor

            // Boundary limits to prevent sticking out
            const tw = tooltip.offsetWidth;
            const th = tooltip.offsetHeight;
            const padding = 10;

            // X is centered (-50%), so the left edge is x - tw/2, right edge is x + tw/2
            const minX = (tw / 2) + padding;
            const maxX = rect.width - (tw / 2) - padding;
            x = Math.max(minX, Math.min(x, maxX));

            // Y is bottom-aligned (-100%), so top edge is y - th, bottom edge is y
            const minY = th + padding;
            const maxY = rect.height - padding;
            y = Math.max(minY, Math.min(y, maxY));

            tooltip.style.transform = `translate(-50%, -100%) translate(${x}px, ${y}px)`;
          });
        }
      });
    }
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initProjectCards);
    } else {
      initProjectCards();
    }
    
    // Soporte para view transitions de Astro
    document.addEventListener('astro:page-load', initProjectCards);
  })();
</script>
