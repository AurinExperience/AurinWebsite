---
import { getLangFromUrl, translations } from '@/i18n';
import styles from './TallCard.module.css';

interface Props {
  letter: string;
  title: string;
  description?: string;
  href?: string;
  className?: string;
  variant?: 'yellow' | 'light' | 'dark';
}

const { letter, title, description, href = '#', className = '', variant = 'dark' } = Astro.props;
const isAbbrev = letter.length > 1;

const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];
---

<a
  href={href}
  class={`${styles['card-link']} ${className}`}
  aria-label={`Ver más sobre ${title}`}
  data-tooltip-text={t.tools.viewServices}
>
  <div class={`${styles.card} ${styles[variant]}`} data-card>
    <div class:list={[styles['card-letter'], isAbbrev && styles['card-letter-abbrev']]} aria-hidden="true">{letter}</div>
    <div class={styles['card-shadow']} aria-hidden="true">
      <img src="/shadow-vector.svg" alt="" />
    </div>
    <div class={styles['card-content']}>
      <p class={styles['card-title']}>{title}</p>
      {description && <p class={styles['card-description']}>{description}</p>}
    </div>
  </div>
</a>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cardLinks = document.querySelectorAll('[data-tooltip-text]');

    cardLinks.forEach(link => {
      const tooltipText = link.getAttribute('data-tooltip-text');

      link.addEventListener('mouseenter', () => {
        window.dispatchEvent(new CustomEvent('showCursorTooltip', {
          detail: { text: tooltipText }
        }));
      });

      link.addEventListener('mouseleave', () => {
        window.dispatchEvent(new CustomEvent('hideCursorTooltip'));
      });
    });
  });
</script>
