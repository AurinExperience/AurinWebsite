---
import { getLangFromUrl, translations } from "@/i18n";
import CounterContainer from "@/components/animation/CounterContainer.astro";
import styles from "./LongCards.module.css";

const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];

const cards = [
  {
    targetValue: 600,
    suffix: "+",
    label: t.about.longCards.clients,
    highlight: false,
  },
  {
    targetValue: 26,
    suffix: "+",
    label: t.about.longCards.years,
    highlight: true,
  },
  {
    targetValue: 16,
    suffix: "+",
    label: t.about.longCards.countries,
    highlight: false,
  },
];
---

<section class={styles.section}>
  <div class={styles.list}>
    {
      cards.map((card, i) => (
        <div
          class={`${styles.card}${card.highlight ? ` ${styles.highlight}` : ""}`}
          data-card
          data-index={i}
        >
          <div class={styles.number}>
            <CounterContainer
              targetValue={card.targetValue}
              suffix={card.suffix}
              fontSize={132}
              textColor={card.highlight ? "#0A0A0A" : "#D0DF00"}
              fontWeight={400}
              startOffset={15}
              className={styles.counter}
            />
          </div>
          <span class={styles.label}>{card.label}</span>
        </div>
      ))
    }
  </div>
</section>

<script>
  const cards = document.querySelectorAll<HTMLElement>("[data-card]");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const card = entry.target as HTMLElement;
        const delay = Number(card.dataset.index) * 120;
        setTimeout(() => {
          card.style.opacity = "1";
          card.style.transform = "none";
          // After scroll-in finishes, clear inline styles so CSS transition: all takes over for hover
          setTimeout(() => {
            card.style.opacity = "";
            card.style.transform = "";
            card.style.transition = "";
          }, 520);
        }, delay);
        observer.unobserve(card);
      });
    },
    { rootMargin: "0px 0px -80px 0px" },
  );

  cards.forEach((card) => {
    card.style.opacity = "0";
    card.style.transform = "translateY(28px)";
    card.style.transition = "opacity 500ms ease, transform 500ms ease";
    observer.observe(card);
  });
</script>
