---
import { getLangFromUrl, translations } from "@/i18n";
import MainButton from "@/components/ui/MainButton.astro";
import styles from "./HeroAbout.module.css";

const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];
---

<section class={styles.hero} id="hero-about">
  <img
    src="https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/Vector-hero-about.svg"
    class={styles.vectorBg}
    aria-hidden="true"
    alt=""
    loading="eager"
    decoding="async"
  />
  <div class={styles.container}>
    <h1 class={styles.title}>
      {t.about.usBanner.title}
    </h1>
    <p class={styles.description}>
      {t.about.usBanner.description1}
      <br aria-hidden="true" />
      <br aria-hidden="true" />
      {t.about.usBanner.description2}
    </p>
    <MainButton text={t.about.usBanner.buttonText} href="/contact" />
  </div>
</section>
