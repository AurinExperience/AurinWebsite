---
import { getLangFromUrl, translations } from '@/i18n';
import MainButton from '@/components/ui/MainButton.astro';
import styles from './OurStory.module.css';

const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];
---

<section class={styles.section}>
  <img
    class={styles.bgImage}
    src="https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/about-how-did-we-get-here.png"
    alt=""
    aria-hidden="true"
    loading="lazy"
  />
  <div class={styles.container}>
    <div class={styles.left}>
      <h2 class={styles.heading}>
        <span class={styles.headingWhite}>{t.about.ourStory.headingWhite}</span>
        <span class={styles.headingYellow}>{t.about.ourStory.headingYellow}</span>
      </h2>
    </div>
    <div class={styles.right}>
      <div class={styles.text}>
        <p>{t.about.ourStory.paragraph1}</p>
        <p>{t.about.ourStory.paragraph2}</p>
      </div>
      <MainButton text={t.about.ourStory.buttonText} href="/contact" />
    </div>
  </div>
</section>
