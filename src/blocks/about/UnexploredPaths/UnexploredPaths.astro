---
import { getLangFromUrl, translations } from '@/i18n';
import MainButton from '@/components/ui/MainButton.astro';
import styles from './UnexploredPaths.module.css';

const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];
---

<section class={styles.section}>
  <div class={styles.container}>
    <h2>
      <span>{t.about.unexploredPaths.titleNormal}</span>
      {t.about.unexploredPaths.titleHighlight}
    </h2>
    <div class={styles.content}>
      <p class={styles.text}>{t.about.unexploredPaths.paragraph1}</p>
      <p class={styles.text}>{t.about.unexploredPaths.paragraph2}</p>
      <MainButton text={t.about.unexploredPaths.buttonText} href="/contact" />
    </div>
  </div>
</section>
