---
/**
 * Template — Project detail content block.
 * Renders the project banner + gallery carousel.
 * Layout shell (Header, Footer, Vignette, etc.) is owned by the page component.
 */
import ProjectBanner from "@/blocks/projects/ProjectBanner/ProjectBanner.astro";
import GalleryCarousel from "@/components/projects/carousel/GalleryCarousel";
import styles from "./Template.module.css";

interface GalleryImage {
  imgUrl: string;
  alt: string;
}

interface ProjectTemplateProps {
  projectTitle: string;
  projectCategories: string[];
  projectDescription: string;
  bannerImage?: string;
  gallery?: GalleryImage[];
  publishDate?: Date;
  featured?: boolean;
  status?: string;
}

interface Props {
  projectData: ProjectTemplateProps;
}

const { projectData } = Astro.props;
---

<article class={styles.projectTemplate}>
  <ProjectBanner
    title={projectData.projectTitle}
    categories={projectData.projectCategories}
    description={projectData.projectDescription}
    bannerImage={projectData.bannerImage}
  />

  {projectData.gallery && projectData.gallery.length > 0 && (
    <section class={styles.gallerySection}>
      <GalleryCarousel
        client:visible
        data={projectData.gallery}
      />
    </section>
  )}
</article>
