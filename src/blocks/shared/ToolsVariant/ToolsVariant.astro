---
import { getLangFromUrl, translations } from "@/i18n";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import TallCard from "@/components/cards/TallCard.astro";
import styles from "./ToolsVariant.module.css";
import "@splidejs/splide/css/core";

const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];

interface HerramientaItem {
  id: string;
  letter: string;
  title: string;
  href: string;
}

interface Props {
  titlePart1?: string;
  titlePart2?: string;
  description?: string;
  items?: HerramientaItem[];
}

const {
  titlePart1 = t.services.tools.titlePart1,
  titlePart2 = t.services.tools.titlePart2,
  description = t.services.tools.description,
  items = [
    {
      id: "diseno-ux-ui",
      letter: "X",
      title: t.services.tools.items[4].title,
      href: "/services",
    },
    {
      id: "desarrollo-web",
      letter: "W",
      title: t.services.tools.items[0].title,
      href: "/services",
    },
    {
      id: "usabilidad",
      letter: "U",
      title: t.services.tools.items[1].title,
      href: "/services",
    },
    {
      id: "branding",
      letter: "B",
      title: t.services.tools.items[2].title,
      href: "/services",
    },
    {
      id: "marketing",
      letter: "M",
      title: t.services.tools.items[3].title,
      href: "/services",
    },
  ],
} = Astro.props;

const uniqueId = `carousel-${Math.random().toString(36).substr(2, 9)}`;

const getVariant = (i: number) => i % 2 === 0 ? "light" : "dark";
---

<section class={styles.herramientasSection}>
  <div class={styles.container}>
    <div class={styles.header}>
      <div class={styles.titleWrapper}>
        <SectionHeading lightText={titlePart1} highlightText={titlePart2} />
      </div>
      <p class={styles.description}>{description}</p>
    </div>

    <!-- Desktop: static flex row -->
    <div class={styles.cardsGrid}>
      {
        items.map((item, i) => (
          <div class={styles.cardItem}>
            <TallCard
              letter={item.letter}
              title={item.title}
              href={item.href}
              variant={getVariant(i)}
            />
          </div>
        ))
      }
    </div>
  </div>

  <!-- Mobile: Splide carousel (full-width, outside container padding) -->
  <section
    class:list={["splide", styles.carouselMobile]}
    id={uniqueId}
    aria-label="Herramientas carousel"
  >
    <div class="splide__track">
      <ul class="splide__list">
        {
          items.map((item, i) => (
            <li
              class="splide__slide"
              role="listitem"
              aria-label={`${i + 1} de ${items.length}: ${item.title}`}
            >
              <TallCard
                letter={item.letter}
                title={item.title}
                href={item.href}
                variant={getVariant(i)}
              />
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</section>

<script>
  import Splide from "@splidejs/splide";

  document.addEventListener("DOMContentLoaded", () => {
    // Animate cards on scroll
    const cards = document.querySelectorAll("[data-card]");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: "0px 0px -50px 0px" },
    );
    cards.forEach((card, i) => {
      (card as HTMLElement).style.transitionDelay = `${i * 0.1}s`;
      observer.observe(card);
    });

    // Init carousel only on mobile
    if (window.innerWidth <= 768) {
      const el = document.querySelector('[id^="carousel-"]');
      if (el) {
        const cardsInSlides = Array.from(
          el.querySelectorAll('.splide__slide [data-card]')
        ) as HTMLElement[];

        function setActiveCard(index: number) {
          cardsInSlides.forEach((card, i) => {
            if (i === index) {
              card.setAttribute('data-mobile-active', '');
            } else {
              card.removeAttribute('data-mobile-active');
            }
          });
        }

        const splide = new Splide(el as HTMLElement, {
          fixedWidth: "65vw",
          padding: "16px",
          accessibility: { slideRole: "" },
          pagination: true,
          arrows: false,
          drag: true,
        });

        // 'moved' fires once per transition (not once per visible slide like 'active')
        splide.on('moved', (index: number) => {
          setActiveCard(index);
        });

        splide.mount();

        // Set first card active after entry animation completes
        setTimeout(() => setActiveCard(0), 700);
      }
    }
  });
</script>
