---
import { translations } from "@/i18n";
import Layout from "@/layouts/Layout.astro";
import {
  PayloadAPI,
  getImageUrl,
  getProjectUrl,
  PROJECT_FILTERS,
} from "@/lib/payload";
import "./ProjectsPayloadPage.css";

interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = translations[lang];

const projects = await PayloadAPI.getProjects(lang);

const seoTitle =
  t.projects?.seo?.title ||
  (lang === "en" ? "Projects - Aurin" : "Proyectos - Aurin");
const seoDescription =
  t.projects?.seo?.description ||
  (lang === "en" ? "Projects by Aurin" : "Proyectos de Aurin");

const ui = {
  heading:
    t.projects?.introduction?.headingLight +
    " " +
    t.projects?.introduction?.headingHighlight,
  description: t.projects?.introduction?.description || "",
  filtersHeading: lang === "en" ? "Project Filters" : "Filtros de Proyectos",
  imagePlaceholder: lang === "en" ? "Project image" : "Imagen del proyecto",
  featuredBadge: lang === "en" ? "Featured" : "Destacado",
  emptyTitle:
    t.projects?.emptyTitle ||
    (lang === "en" ? "No projects available" : "No hay proyectos disponibles"),
  emptyDesc:
    t.projects?.emptyDesc ||
    (lang === "en"
      ? "We'll add new projects soon."
      : "Pronto agregaremos nuevos proyectos."),
};
---

<Layout title={seoTitle} description={seoDescription}>
  <main class="projects-page">
    <section class="hero">
      <div class="container">
        <h1>{ui.heading}</h1>
        <p>{ui.description}</p>
      </div>
    </section>

    <section class="filters">
      <div class="container">
        <h2>{ui.filtersHeading}</h2>
        <div class="filter-buttons" id="filter-buttons">
          {
            PROJECT_FILTERS.map((filter) => (
              <button
                type="button"
                class={`filter-btn ${filter.value === "all" ? "active" : ""}`}
                data-filter={filter.value}
                data-is-all={filter.value === "all"}
              >
                <span class="filter-checkbox">
                  <svg
                    class="checkmark"
                    width="12"
                    height="10"
                    viewBox="0 0 12 10"
                    fill="none"
                  >
                    <path
                      d="M1 5L4.5 8.5L11 1.5"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </span>
                <span class="filter-label">{filter.label}</span>
              </button>
            ))
          }
        </div>
      </div>
    </section>

    <section class="projects-grid">
      <div class="container">
        {
          projects.length > 0 ? (
            <div class="grid" id="projects-grid">
              {projects.map((project) => (
                <article
                  class="project-card"
                  data-filters={JSON.stringify(project.projectFilters || [])}
                >
                  <a href={getProjectUrl(project, lang)}>
                    <div class="project-image">
                      {project.hero.bannerImage ? (
                        <img
                          src={getImageUrl(project.hero.bannerImage.url)}
                          alt={project.hero.bannerImage.alt || project.title}
                          width={project.hero.bannerImage.width}
                          height={project.hero.bannerImage.height}
                          loading="lazy"
                        />
                      ) : (
                        <div class="placeholder">
                          <span>{ui.imagePlaceholder}</span>
                        </div>
                      )}
                    </div>

                    <div class="project-content">
                      <div class="project-meta">
                        {project.featured && (
                          <span class="featured-badge">{ui.featuredBadge}</span>
                        )}
                      </div>

                      <h3 class="project-title">{project.title}</h3>

                      <div class="project-services">
                        {project.hero.services.slice(0, 3).map((service) => (
                          <span class="service-tag">{service.name}</span>
                        ))}
                        {project.hero.services.length > 3 && (
                          <span class="service-more">
                            +{project.hero.services.length - 3}
                          </span>
                        )}
                      </div>

                      <p class="project-description">
                        {project.hero.description}
                      </p>
                    </div>
                  </a>
                </article>
              ))}
            </div>
          ) : (
            <div class="empty-state">
              <h3>{ui.emptyTitle}</h3>
              <p>{ui.emptyDesc}</p>
            </div>
          )
        }
      </div>
    </section>
  </main>
</Layout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const filterButtons = document.querySelectorAll(".filter-btn");
    const projectCards = document.querySelectorAll(".project-card");
    const activeFilters = new Set(["all"]);

    function updateProjectsVisibility() {
      projectCards.forEach((card) => {
        const cardFilters = JSON.parse(
          card.getAttribute("data-filters") || "[]",
        );

        if (activeFilters.has("all")) {
          (card as HTMLElement).style.display = "block";
          return;
        }

        if (activeFilters.size === 0) {
          (card as HTMLElement).style.display = "none";
          return;
        }

        const hasMatchingFilter = cardFilters.some((filter: string) =>
          activeFilters.has(filter),
        );

        (card as HTMLElement).style.display = hasMatchingFilter
          ? "block"
          : "none";
      });
    }

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const filterValue = button.getAttribute("data-filter");
        const isAllButton = button.getAttribute("data-is-all") === "true";

        if (isAllButton) {
          activeFilters.clear();
          activeFilters.add("all");
          filterButtons.forEach((btn) => btn.classList.remove("active"));
          button.classList.add("active");
        } else {
          activeFilters.delete("all");
          filterButtons.forEach((btn) => {
            if (btn.getAttribute("data-is-all") === "true") {
              btn.classList.remove("active");
            }
          });

          if (activeFilters.has(filterValue!)) {
            activeFilters.delete(filterValue!);
            button.classList.remove("active");
          } else {
            activeFilters.add(filterValue!);
            button.classList.add("active");
          }

          if (activeFilters.size === 0) {
            activeFilters.add("all");
            filterButtons.forEach((btn) => {
              if (btn.getAttribute("data-is-all") === "true")
                btn.classList.add("active");
            });
          }
        }

        updateProjectsVisibility();
      });
    });
  });
</script>
