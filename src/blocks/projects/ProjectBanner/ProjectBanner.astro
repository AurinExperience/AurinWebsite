---
import styles from './ProjectBanner.module.css';

interface Props {
  title: string;
  categories: string[];
  description: string;
  clientLogo?: string;
  heroImage?: string;
}

const { title, categories, description, clientLogo, heroImage } = Astro.props;
---

<section class={styles.banner}>
  <div class={styles.container}>
    <div class={styles.information}>
      {clientLogo && (
        <div class={styles.logoWrapper}>
          <img src={clientLogo} alt={`${title} logo`} class={styles.logoImage} />
        </div>
      )}
      
      <div class={styles.titleWrapper}>
        <h1 class={styles.title}>{title}</h1>
      </div>

      {categories && categories.length > 0 && (
        <div class={styles.categories}>
          {categories.map((category) => (
            <span class={styles.category}>{category}</span>
          ))}
        </div>
      )}
    </div>

    <div class={styles.heroImageWrapper}>
      {heroImage ? (
        <img src={heroImage} alt={title} class={styles.heroImage} />
      ) : (
        <div class={styles.imagePlaceholder}></div>
      )}
    </div>
  </div>
</section>

