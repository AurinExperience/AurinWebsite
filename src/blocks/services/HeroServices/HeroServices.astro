---
import { getLangFromUrl, translations } from '@/i18n';
import MainButton from '@/components/ui/MainButton.astro';
import ScrollReveal from '@/components/animation/ScrollReveal.astro';
import styles from './HeroServices.module.css';

const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];
---

<section class={styles.hero}>
  <img
    src="https://pub-d17bbbdbf8e348c5a57c8168ad69c92f.r2.dev/heroservices.svg"
    alt=""
    class={styles.decor}
    aria-hidden="true"
  />
  <div class={styles.inner}>
    <div class={styles.heading}>
      <p class={styles.subtitle}>{t.services.banner.subtitle}</p>
      <ScrollReveal
        text={t.services.banner.title}
        tag="h1"
        textClass="main-title"
        baseOpacity={0.15}
        baseRotation={5}
        blurStrength={6}
        enableBlur={true}
      />
    </div>
    <div class={styles.body}>
      <p class={styles.description}>{t.services.banner.description}</p>
      <MainButton text={t.services.banner.buttonText} href="/contact" />
    </div>
  </div>
</section>
