---
import { getLangFromUrl, translations } from "@/i18n";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import ToolsSuite from "@/components/ToolsSuite/ToolsSuite.astro";
import styles from "./ToolsScrollStory.module.css";

const currentLang = getLangFromUrl(Astro.url);
const t = translations[currentLang];

interface HerramientaItem {
  id: string;
  letter: string;
  title: string;
  href: string;
}

interface Props {
  titlePart1?: string;
  titlePart2?: string;
  description?: string;
  items?: HerramientaItem[];
}

const {
  titlePart1 = t.services.tools.homeTitlePart1,
  titlePart2 = t.services.tools.homeTitlePart2,
  description = t.services.tools.homeDescription,
  items = [
    {
      id: "diseno-ux-ui",
      letter: "UX/UI",
      title: t.services.tools.items[4].title,
      href: "#",
    },
    {
      id: "desarrollo-web",
      letter: "Dev",
      title: t.services.tools.items[0].title,
      href: "#",
    },
    {
      id: "branding",
      letter: "Br",
      title: t.services.tools.items[2].title,
      href: "#",
    },
  ],
} = Astro.props;
---

<section class={styles.toolsSection}>
  <div class={styles.container}>
    <div class={styles.header}>
      <div class={styles.headerContent}>
        <SectionHeading lightText={titlePart1} highlightText={titlePart2} />
        <p class={styles.description}>{description}</p>
      </div>
    </div>
  </div>

  <ToolsSuite
    items={items}
    toolsDetail={t.services.toolsDetail.slice(0, 3)}
    variant="textBelow"
  />
</section>
